# Optional: override path to INI (defaults to config.ini in cwd)
# CONFIG_INI=/opt/app/config.ini

# Skip embedded SQLx migrations on boot (for special cases only)
# SKIP_MIGRATIONS=1

# For `sqlx migrate` CLI only — use the same DSN as [POSTGRES] in config.ini
# DATABASE_URL=postgresql://postgres:changeme@127.0.0.1:5432/app
